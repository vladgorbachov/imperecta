# PriceRadar / Imperecta - Environment variables for cloud deploy
# Copy to .env and fill in your values

# Database (Supabase: use connection pooler port 6543)
DATABASE_URL=postgresql+asyncpg://user:pass@host:6543/postgres

# Redis (Upstash: use rediss:// for TLS)
REDIS_URL=rediss://default:pass@host:6379

# JWT - generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-generate-with-secrets-token-urlsafe-48
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Claude API for AI digest
CLAUDE_API_KEY=sk-ant-api03-xxx

# Resend for transactional email
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@imperecta.com

# Telegram bot for notifications
TELEGRAM_BOT_TOKEN=123:AAA

# Sentry for error tracking (optional)
SENTRY_DSN=

# Proxies for scraping (comma-separated)
PROXY_LIST=

# App config
APP_ENV=development
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Railway injects PORT
PORT=8000
